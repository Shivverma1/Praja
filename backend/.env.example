# ─── Instagram Graph API ─────────────────────────────────────────────────────
# Get from: https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_account_id

# ─── RapidAPI (fallback scraper) ─────────────────────────────────────────────
# Get from: https://rapidapi.com/search/instagram
RAPIDAPI_KEY=your_rapidapi_key_here

# ─── Google Gemini API ────────────────────────────────────────────────────────
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── App Config ──────────────────────────────────────────────────────────────
# Set to "demo" to use realistic mock data (no API keys needed)
# Set to "live" to use real Instagram + Gemini APIs
APP_MODE=demo

DATABASE_URL=sqlite+aiosqlite:///./praja.db
FRONTEND_URL=http://localhost:5173
